{
  "name": "@exhibition/admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/with-formal-cloud-env.cjs next dev --port 3100",
    "dev:tunnel": "SERVER_ADMIN_API_ENTRY_MODE=ssh_tunnel node ./scripts/with-formal-cloud-env.cjs next dev --port 3100",
    "dev:local": "SERVER_ADMIN_API_ENTRY_MODE=local_dev node ./scripts/with-formal-cloud-env.cjs next dev --port 3100",
    "build": "node ./scripts/with-formal-cloud-env.cjs next build",
    "start": "node ./scripts/with-formal-cloud-env.cjs next start --port 3100",
    "lint": "eslint .",
    "test:admin-side:prepare": "rm -rf test-dist && tsc -p tsconfig.admin-tests.json",
    "test:admin-side": "npm run test:admin-side:prepare && node --test test/admin-env.test.cjs test/admin-route-guard.test.cjs test/admin-api-client.test.cjs test/admin-review.test.cjs test/admin-governance-penalty.test.cjs test/admin-governance-appeal.test.cjs test/admin-project-review.test.cjs test/admin-audit.test.cjs test/admin-template-config.test.cjs test/admin-published-change-review.test.cjs"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5"
  }
}
